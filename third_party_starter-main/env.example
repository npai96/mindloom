# API key and client ID — shown once during registration, store securely
PARADIGM_API_KEY=ofs_tp_XXXXX.XXXXX
PARADIGM_CLIENT_ID=tp_XXXXX

# API base URL — used for server-side API calls (nodes, tags, schemas, etc.)
PARADIGM_BASE_URL=https://api.ofself.ai/api/v1

# App URL — used for browser redirect to /authorize (the consent page)
# This is the frontend origin, NOT the API base. See README for details.
PARADIGM_APP_URL=https://app.ofself.ai

# Your app's callback URL — must exactly match what you registered on the dashboard
APP_CALLBACK_URL=http://localhost:3000/callback
